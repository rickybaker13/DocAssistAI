# DocAssistAI — Production Environment Variables
# Copy to .env and fill in real values:
#   cp .env.example .env && nano .env

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_A_RANDOM_PASSWORD
POSTGRES_USER=docassistai
POSTGRES_DB=docassistai

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET

# ── AWS Bedrock (AI provider) ─────────────────────────────────────────────────
EXTERNAL_AI_TYPE=bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6-20250514-v1:0

# ── Square Payments ──────────────────────────────────────────────────────────
SQUARE_WEB_APP_ID=sq0idp-xxxx
SQUARE_LOCATION_ID=L1234567890
SQUARE_ACCESS_TOKEN=EAAAxxxx
SQUARE_ENVIRONMENT=production

# ── Email (Resend) ──────────────────────────────────────────────────────────
# Sign up at https://resend.com — verify your sending domain there.
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=DocAssistAI <noreply@docassistai.app>

# ── Cron Jobs ───────────────────────────────────────────────────────────────
# Shared secret for backend/scripts/cron-billing.sh
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET

# ── Optional overrides (defaults are set in docker-compose.prod.yml) ──────────
# FRONTEND_URL=https://www.docassistai.app
# PRESIDIO_MIN_SCORE=0.7
# PRESIDIO_TIMEOUT_MS=5000
# WHISPER_TIMEOUT_MS=120000
