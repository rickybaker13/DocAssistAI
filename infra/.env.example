# DocAssistAI — Production Environment Variables
# Copy to .env and fill in real values:
#   cp .env.example .env && nano .env

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_A_RANDOM_PASSWORD
POSTGRES_USER=docassistai
POSTGRES_DB=docassistai

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET

# ── Anthropic AI (direct API) ────────────────────────────────────────────────
EXTERNAL_AI_TYPE=anthropic
ANTHROPIC_API_KEY=sk-ant-xxxx

# Override the model used for /generate (note generation).
# Defaults to provider's default model (Sonnet) if unset.
SCRIBE_GENERATE_MODEL=claude-haiku-4-5-20251001

# ── Square Payments ──────────────────────────────────────────────────────────
SQUARE_WEB_APP_ID=sq0idp-xxxx
SQUARE_LOCATION_ID=L1234567890
SQUARE_ACCESS_TOKEN=EAAAxxxx
SQUARE_ENVIRONMENT=production

# ── Email (Resend) ──────────────────────────────────────────────────────────
# Sign up at https://resend.com — verify your sending domain there.
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=DocAssistAI <noreply@docassistai.app>

# ── Cron Jobs ───────────────────────────────────────────────────────────────
# Shared secret for backend/scripts/cron-billing.sh
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET

# ── Groq (fast Whisper transcription) ────────────────────────────────────────
# Sign up at https://console.groq.com — free tier available.
# If unset, falls back to self-hosted Whisper container.
GROQ_API_KEY=gsk_xxxxxxxxxxxx

# ── Optional overrides (defaults are set in docker-compose.prod.yml) ──────────
# FRONTEND_URL=https://www.docassistai.app
# PRESIDIO_MIN_SCORE=0.7
# PRESIDIO_TIMEOUT_MS=5000
# WHISPER_TIMEOUT_MS=120000
