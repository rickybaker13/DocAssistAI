# ─── Database ─────────────────────────────────────────────────────────────────
# Automatically injected by Railway when using Railway PostgreSQL service.
# For local dev: set a local PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-64-char-random-string
COOKIE_SECRET=change-me-64-char-random-string

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Option A: Direct Anthropic API (default)
EXTERNAL_AI_TYPE=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Option B: Google Gemini via OpenRouter
#   EXTERNAL_AI_TYPE=openrouter
#   OPENROUTER_API_KEY=sk-or-...
#   OPENROUTER_MODEL=google/gemini-2.0-pro-exp-02-05

# ─── Presidio (PII De-identification) ─────────────────────────────────────────
# Point to your DigitalOcean droplet running docker-compose (Presidio + Whisper).
PRESIDIO_ANALYZER_URL=http://<DROPLET_IP>:5002
PRESIDIO_ANONYMIZER_URL=http://<DROPLET_IP>:5001
PRESIDIO_MIN_SCORE=0.7
PRESIDIO_TIMEOUT_MS=5000

# ─── Whisper (Speech-to-Text) ────────────────────────────────────────────────
# Self-hosted Whisper on the DigitalOcean droplet. Omit to use OpenAI cloud API.
WHISPER_API_URL=http://<DROPLET_IP>:9000
WHISPER_TIMEOUT_MS=120000


# ─── Square Payments (Scribe billing) ────────────────────────────────────────
# Required for embedded card entry in /api/scribe/billing/square-config
SQUARE_WEB_APP_ID=sq0idp-xxxx
# Optional legacy aliases also supported: SQUARE_APPLICATION_ID or SQUARE_APP_ID
SQUARE_LOCATION_ID=L1234567890
SQUARE_ACCESS_TOKEN=EAAAxxxx
# Optional legacy aliases also supported: SQUARE_TOKEN or SQUARE_SECRET_ACCESS_TOKEN

# Optional hosted checkout aliases for older clients
SQUARE_CHECKOUT_URL=https://square.link/u/your-card-checkout-link
SQUARE_WEBHOSTED_CHECKOUT_URL=https://square.link/u/your-card-checkout-link
# sandbox (default) or production
SQUARE_ENVIRONMENT=sandbox

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Sign up at https://resend.com — verify your sending domain there.
# If omitted, emails are logged to console instead of sent.
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=DocAssistAI <noreply@docassistai.app>

# ─── Cron Jobs ──────────────────────────────────────────────────────────────
# Shared secret used by backend/scripts/cron-billing.sh to authenticate
# cron requests. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=change-me-random-string

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set to your Vercel deployment URL (no trailing slash).
FRONTEND_URL=https://your-app.vercel.app

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
